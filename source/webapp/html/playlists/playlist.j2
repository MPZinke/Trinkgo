{% from "playlists/song.j2" import render_song %}

<!DOCTYPE html>
<html>
	<title>
		{{ playlist.name }} Playlist
	</title>
	<body>

		<a
			href="https://open.spotify.com/track/{{ playlist.id }}"
		>
			Open In Spotify
		</a>

		<h2>
			Sets
		</h2>
		<table>
			<tr>
				<td>
					<a
						href="/playlists/{{ playlist.id }}/sets/new"
					>
						+ New Set
					</a>
				</td>
			</tr>
			{% for playlist_set in playlist_sets %}
				<tr>
					<td>
						<a
							href="/playlists/{{ playlist.id }}/sets/{{ playlist_set.id }}"
						>
							{{ playlist_set.name }}
						</a>
					</td>
				</tr>
			{% endfor %}
		</table>

		<h2>
			Songs
		</h2>
		<table>
			{% for song in playlist.songs %}
				{{ render_song(loop.index, song) }}
			{% endfor %}
		</table>

		<form
			method="POST"
			action="/playlists/{{ playlist.id }}"
		>
			<input
				id="number_of_boards-input"
				name="number_of_boards-input"
				type="number"
				value="1"
				min="1"
			/>
			<button
				onclick=""
			>
				Create Boards
			</button>
		</form>
	</body>
</html>

{% include("player.j2") %}

<script>
	function get_start_and_play_song(button, uri)
	{
		var play_buttons = document.getElementsByClassName("play-button");
		for(var x = 0; x < play_buttons.length; x++)
		{
			let play_button = play_buttons[x];;
			play_button.innerHTML = "Play";
			let button_id = play_button.id.match(/play_([a-zA-Z0-9]{22})-button/)[1];
			play_button.onclick = () => get_start_and_play_song(play_button, button_id);
		}

		button.innerHTML = "Pause";
		button.onclick = () => update_button_and_pause(button, uri);

		let action = function()
		{
			button.onclick = () => get_start_and_play_song(button, uri);
			button.innerHTML = "Play";
		};

		PLAYER.play_song(uri);
	}


	function update_button_and_pause(button, id)
	{
		button.onclick = () => get_start_and_play_song(button, id);
		button.innerHTML = "Play";

		PLAYER.pause();
	}
</script>
