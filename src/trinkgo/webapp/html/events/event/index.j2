<!DOCTYPE html>
<html>
	<title>
		{{ event.name }} Event
	</title>

	<body>
		<header>
			<a
				href="/"
			>
				⌂
			</a>
			&gt;
			<a
				href="/events"
			>
				Events
			</a>
			&gt; {{ event.name }}
		</header>

		<h1>
			{{ event.name }} ({{ event.date }})
		</h1>

		<h2>
			<a
				href="/events/{{ event.id }}/rounds"
			>
				Rounds
			</a>
		</h2>

		<a
			href="/events/{{ event.id }}/rounds/new"
		>
			+ New Round
		</a>

		<br/>
		<br/>

		<table>
			<thead>
				<tr>
					<th>
						Round
					</th>
					<th>
						Playlist Set
					</th>
					<th>
					</th>
				</tr>
			</thead>

			<tbody>
				{% for round in event.rounds %}
					<tr>
						<td>
							<a
								href="/events/{{ event.id }}/rounds/{{ round.id }}"
							>
								{{ round.name }}
							</a>
						</td>
						<td>
							<a
								href="/playlists/{{ round.playlist_set.playlist.id }}/sets/{{ round.playlist_set.id }}"
							>
								{{ round.playlist_set.name }}
							</a>
						</td>
						<td>
							{% if round.ended is false %}
								<a
									href="/events/{{ round.event.id }}/rounds/{{ round.id }}/play"
								>
									<button>
										{% if round.start is none %}
											Start
										{% else %}
											Continue
										{% endif %}
									</button>
								</a>
							{% else %}
								Finished
							{% endif %}
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</body>
</html>
