<!DOCTYPE html>
<html>
	<title>
		Play {{ round.name }}
	</title>

	<body>
		<header>
			<a
				href="/"
			>
				⌂
			</a>
			&gt;
			<a
				href="/events"
			>
				Events
			</a>
			&gt;
			<a
				href="/events/{{ round.event.id }}"
			>
				{{ round.event.name }}
			</a>
			&gt;
			<a
				href="/events/{{ round.event.id }}/rounds"
			>
				Rounds
			</a>
			&gt;
			<a
				href="/events/{{ round.event.id }}/rounds/{{ round.event.id }}"
			>
				{{ round.name }}
			</a>
			&gt; Play
		</header>

		<h1>
			Play {{ round.name }}
		</h1>

		<table>
			<tr>
				<td>
					Playlist Set
				</td>
				<td>
					<a
						href="/playlists/{{ round.playlist_set.playlist.id }}/sets/{{ round.playlist_set.id }}"
					>
						{{ round.playlist_set.name }}
					</a>
				</td>
			</tr>
			<tr>
				<td>
					Size
				</td>
				<td>
					{{ round.size }}
				</td>
			</tr>
			<tr>
				<td>
					Started
				</td>
				<td>
					{{ round.start }}
				</td>
			</tr>
			<tr>
				{% if round.ended is false %}
					<td
						colspan="2"
					>
						<form
							method="POST"
							action="/events/{{ round.event.id }}/rounds/{{ round.id }}/end"
						>
							<button>
								End
							</button>
						</form>
					</td>
				{% else %}
					<td>
						Ended
					</td>
					<td>
						{{ round.ended }}
					</td>
				{% endif %}
			</tr>
			<tr>
				<td>
					<a
						href="/events/{{ round.event.id }}/rounds/{{ round.id }}/cards"
					>
						Cards ({{ round.cards | length }})
					</a>
				</td>
			</tr>
		</table>

		<button
			id="play_next_random-button"
			onclick="play_next()"
		>
			Play Random
		</button>

		<table>
			<tr>
				{# TODO: make scrollable #}
				<td
					style="vertical-align: top;"
					width="50%"
				>
				<div style="overflow-y: scroll;">
					<h2>
						Upcoming
					</h2>

					<table
						id="unplayed_songs-table"
					>
						{% for set_song in round.playlist_set.set_songs %}
							{% if set_song not in round.played_set_songs %}
								{% set index=loop.index %}
								{% include "events/event/rounds/round/play/_unplayed_song.j2" with context %}
							{% endif %}
						{% endfor %}
					</table>
				</div>
				</td>

				<td
					style="vertical-align: top;"
					width="50%"
				>
					<h2>
						Played
					</h2>
					<table>
						<tbody
							id="played_songs-tbody"
						>
							{% for set_song in round.played_set_songs %}
								{% set index=round.played_set_songs|length - loop.index + 1 %}
								{% include "events/event/rounds/round/play/_played_song.j2" with context %}
							{% endfor %}
						</tbody>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>

{% include("player.j2") %}

<script>
	const PLAY_NEXT_RANDOM = document.getElementById("play_next_random-button");
	const PLAYED_SONGS_TABLE = document.getElementById("played_songs-tbody");


	async function play_next(set_song_id=null)
	{
		PLAY_NEXT_RANDOM.disabled = true;

		try
		{
			let response = await fetch(
				`/api/rounds/{{ round.id }}/played_set_songs/new`,
				{
					method: `POST`,
					headers: {"Content-Type": "application/json"},
					body: JSON.stringify({set_song_id})
				}
			);

			if(response.status != 200)
			{
				throw new Error(`Unexpected ${response.status} Error: ${await response.text()}`);
			}
			let response_json = await response.json();

			let created_element = document.createElement("tbody");
			created_element.innerHTML = response_json.html;
			PLAYED_SONGS_TABLE.prepend(created_element.firstChild);

			document.getElementById(`unplayed_song_${response_json.set_song_id}-tr`).remove();

			let on_play = async () =>
			{
				let play_button = document.getElementById(`played_set_song_${response_json.set_song_id}-button`);
				play_button.innerHTML = "Pause";
				play_button.onclick = async () => await PLAYER.pause();
			}
			let on_pause = async () =>
			{
				let play_button = document.getElementById(`played_set_song_${response_json.set_song_id}-button`);
				play_button.innerHTML = "Play Again";
				play_button.onclick = async () =>
				{
					await play_again(
						play_button,
						response_json.set_song_id,
						null,
						response_json.duration
					);
				};
			}
			await PLAYER.play_set_song(response_json.set_song_id, on_play, on_pause, null, response_json.duration);
		}
		catch(error)
		{
			console.error(error);
			alert(error);
		}

		PLAY_NEXT_RANDOM.disabled = false;
	}


	async function play_again(button, set_song_id, start, duration)
	{
		button.disabled = true;

		try
		{
			let on_play = async () =>
			{
				button.innerHTML = "Pause";
				button.onclick = async () => await PLAYER.pause();
				button.disabled = false;
			}
			let on_pause = async () =>
			{
				button.innerHTML = "Play Again";
				button.onclick = async () => await play_again(button, set_song_id, start, duration);
			}
			await PLAYER.play_set_song(set_song_id, on_play, on_pause, start, duration);
		}
		catch(error)
		{
			alert(error);
		}
	}
</script>
