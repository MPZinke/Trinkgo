<!DOCTYPE html>
<html>
	<body>

		<form
			method="POST"
		>
			<input
				name="redirect_url-input"
				value="{{ redirect_url }}"
				hidden
			/>
			<div
				class="mb-3 row"
			>
				<label
					for="username-input"
					class="col-sm-2 col-form-label"
				>
					Username
				</label>
				<div
					class="col-sm-10"
				>
					<input
						id="username-input"
						name="username-input"
						type="text"
						class="form-control"
						value=""
					>
				</div>
			</div>
			<div
				class="mb-3 row">
				<label
					for="password-input"
					class="col-sm-2 col-form-label"
				>
					Password
				</label>
				<div
					class="col-sm-10"
				>
					<input
						id="password-input"
						name="password-input"
						type="password"
						class="form-control"
					>
				</div>
			</div>
			<button
				class="btn btn-primary"
				type="submit"
			>
				Login
			</button>
		</form>
	</body>
</html>