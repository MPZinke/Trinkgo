<!DOCTYPE html>
<html>
	<title>
		{{ playlist_set.name }} Set
	</title>

	<body>
		<header>
			<a
				href="/"
			>
				⌂
			</a>
			&gt;
			<a
				href="/playlists"
			>
				Playlists
			</a>
			&gt;
			<a
				href="/playlists/{{ playlist_set.playlist.id }}"
			>
				{{ playlist_set.playlist.title }}
			</a>
			&gt;
			<a
				href="/playlists/{{ playlist_set.playlist.id }}/sets"
			>
				Sets
			</a>
			&gt; {{ playlist_set.name }}
		</header>

		<h1>
			'{{ playlist_set.playlist.title }}' {{ playlist_set.name }} Set
		</h1>

		<a
			href="https://open.spotify.com/playlist/{{ playlist_set.playlist.uri }}"
			target="_blank"
		>
			Open In Spotify
		</a>

		<table>
			{% for set_song in playlist_set.set_songs %}
				{% set index=loop.index %}
				{% include "playlists/playlist/sets/_song.j2" with context %}
			{% endfor %}
		</table>

		<form
			method="POST"
			action="/playlists/{{ playlist_set.playlist.id }}"
		>
			<input
				id="number_of_boards-input"
				name="number_of_boards-input"
				type="number"
				value="1"
				min="1"
			/>
			<button
				onclick=""
			>
				Create Boards
			</button>
		</form>
	</body>
</html>

{% include("player.j2") %}

<script>
	async function get_start_and_play_song(button, set_song_id)
	{
		button.disabled = true;

		let on_play = () =>
		{
			button.innerHTML = "Pause";
			button.onclick = async () => await PLAYER.pause();
			button.disabled = false;
		}

		let on_pause = () =>
		{
			button.innerHTML = "Play";
			button.onclick = async () => get_start_and_play_song(button, set_song_id);
		}

		let start = document.getElementById(`set_song_start-${set_song_id}-input`).value;
		let duration = document.getElementById(`set_song_duration-${set_song_id}-input`).value;
		try
		{
			await PLAYER.play_set_song(set_song_id, on_play, on_pause, start, duration);
		}
		catch(error)
		{
			alert(error);
		}
	}


	async function update_set_song(set_song_id)
	{
		let playlist_id = window.location.pathname.split("/")[2];

		let label = document.getElementById(`set_song_label-${set_song_id}-input`).value;
		let start = document.getElementById(`set_song_start-${set_song_id}-input`).value;
		let duration = document.getElementById(`set_song_duration-${set_song_id}-input`).value;

		try
		{
			let response = await fetch(
				`/api/set_songs/${set_song_id}/update`,
				{
					method: `POST`,
					headers: {"Content-Type": "application/json"},
					body: JSON.stringify({playlist_id, label, start, duration})
				}
			);
			if(response.status != 204)
			{
				return alert(`${response.status}`+response.body);
			}
		}
		catch(error)
		{
			console.error(error);
			alert(error);
		}
	}


	function update_duration(set_song_id, song_length)
	{
		const start_input = document.getElementById(`set_song_start-${set_song_id}-input`);
		const duration_input = document.getElementById(`set_song_duration-${set_song_id}-input`);

		if(parseInt(start_input.value) < 0)
		{
			parseInt(start_input.value) = 0;
		}
		if(song_length < parseInt(start_input.value))
		{
			parseInt(start_input.value) = song_length;
		}

		if(parseInt(start_input.value) + parseInt(duration_input.value) > song_length)
		{
			console.log(parseInt(start_input.value));
			console.log(typeof parseInt(start_input.value));
			console.log(parseInt(duration_input.value));
			console.log(typeof parseInt(duration_input.value));
			console.log(parseInt(start_input.value) + parseInt(duration_input.value));
			console.log(song_length);
			console.log(typeof song_length);
			parseInt(duration_input.value) = song_length - parseInt(start_input.value);
		}
	}
</script>
