<!DOCTYPE html>
<html>
	<title>
		{{ playlist_set.name }} Set
	</title>

	<body>
		<header>
			<a
				href="/"
			>
				⌂
			</a>
			&gt;
			<a
				href="/playlists"
			>
				Playlists
			</a>
			&gt;
			<a
				href="/playlists/{{ playlist_set.playlist.id }}"
			>
				{{ playlist_set.playlist.title }}
			</a>
			&gt;
			<a
				href="/playlists/{{ playlist_set.playlist.id }}/sets"
			>
				Sets
			</a>
			&gt; {{ playlist_set.name }}
		</header>

		<h1>
			'{{ playlist_set.playlist.title }}' {{ playlist_set.name }} Set
		</h1>

		<a
			href="https://open.spotify.com/playlist/{{ playlist_set.playlist.uri }}"
			target="_blank"
		>
			Open In Spotify
		</a>

		<table>
			{% for set_song in playlist_set.set_songs %}
				{% set index=loop.index %}
				{% include "playlists/playlist/sets/_song.j2" with context %}
			{% endfor %}
		</table>

		<form
			method="POST"
			action="/playlists/{{ playlist_set.playlist.id }}"
		>
			<input
				id="number_of_boards-input"
				name="number_of_boards-input"
				type="number"
				value="1"
				min="1"
			/>
			<button
				onclick=""
			>
				Create Boards
			</button>
		</form>
	</body>
</html>

{% include("player.j2") %}

<script>
	{% include "playlists/playlist/sets/set.js" with context %}
</script>
